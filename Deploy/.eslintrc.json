{
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true
  },
  "globals": {
    "chrome": "readonly",
    "SG_CONSTS": "readonly",
    "SG_CRYPTO": "readonly",
    "SG_FINGERPRINT": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-redeclare": ["error", { "builtinGlobals": true }],
    "no-var": "warn",
    "prefer-const": "warn",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-console": "off"
  }
}
