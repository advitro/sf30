{
  "manifest_version": 3,
  "name": "Shift Grabber — Licensed",
  "version": "2.1.0",
  "description": "Direct API shift grabber — polls 7-day window every 1s per tab, instant claim on detection. Burst reloads at 5-min marks, DOM backup, HUD, Telegram alerts. Protected by license.",
  "permissions": ["tabs", "storage", "scripting", "alarms"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://atoz.amazon.work https://atoz-apps.amazon.work https://api.telegram.org https://project-qgqvr.vercel.app"
  },
  "host_permissions": [
    "https://atoz.amazon.work/*",
    "https://atoz-apps.amazon.work/*",

    "https://api.telegram.org/*",
    "https://project-qgqvr.vercel.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Shift Grabber Control",
    "default_popup": "popup/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/click.mp3"],
      "matches": ["https://atoz.amazon.work/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://atoz.amazon.work/*"],
      "js": ["src/shared/constants.js", "src/shared/crypto.js", "src/shared/fingerprint.js", "src/shared/license-validator.js", "src/content/main.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": ["https://atoz.amazon.work/*"],
      "js": ["src/shared/constants.js", "src/shared/fingerprint.js", "src/shared/license-validator.js", "src/content/api-layer.js"],
      "run_at": "document_end",
      "world": "MAIN",
      "all_frames": false
    }
  ]
}
