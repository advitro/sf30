{
  "env": {
    "browser": true,
    "es2021": true,
    "webextensions": true
  },
  "globals": {
    "chrome": "readonly",
    "crypto": "readonly",
    "SG_CONSTS": "readonly",
    "SG_CRYPTO": "readonly",
    "SG_FINGERPRINT": "readonly",
    "SG_LICENSE": "readonly"
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-empty": ["warn", { "allowEmptyCatch": false }],
    "no-var": "off",
    "prefer-const": "off",
    "semi": ["warn", "always"],
    "quotes": ["warn", "double"]
  }
}
