# SF30 License Server Configuration

# Port to run the server on (local development only)
PORT=3000

# Default license expiry in days
DEFAULT_DAYS=30

# SQLite database file path (local development only)
DB_PATH=./licenses.db

# Admin API Bearer token (required for /api/admin/*)
# Generate a strong random token: openssl rand -base64 32
API_TOKEN=change-me-to-a-secure-random-token

# Postgres connection string (Vercel / serverless deployments)
# Automatically set by Vercel Postgres. For external providers, set manually:
# POSTGRES_URL=postgres://user:pass@host:5432/dbname
