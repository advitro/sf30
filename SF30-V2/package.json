{
  "name": "SF30 V2.0",
  "version": "2.0.0",
  "description": "SF30 V2.0 — Stealth Shift Grabber Chrome Extension (MV3)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:debug": "vite build --mode debug",
    "build:zip": "npm run build && node scripts/zip.cjs",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "validate": "node scripts/validate-build.cjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "archiver": "^7.0.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-webextension-mock": "^3.8.9",
    "terser": "^5.46.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-web-extension": "^4.1.3"
  },
  "keywords": [
    "chrome-extension",
    "shift-grabber",
    "amazon-atoz",
    "mv3"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true
}
